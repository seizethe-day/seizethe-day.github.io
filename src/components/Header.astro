---
import { SITE_TITLE, GITHUB_URL } from '../consts';
import HeaderLink from './HeaderLink.astro';
import LangToggle from './LangToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">
				<span data-i18n-zh>首页</span><span data-i18n-en>Home</span>
			</HeaderLink>
			<HeaderLink href="/blog">
				<span data-i18n-zh>文章</span><span data-i18n-en>Blog</span>
			</HeaderLink>
			<HeaderLink href="/about">
				<span data-i18n-zh>关于</span><span data-i18n-en>About</span>
			</HeaderLink>
		</div>
		<div class="utility-links">
			<a class="github-link" href={GITHUB_URL} target="_blank" rel="noopener" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<ThemeToggle />
			<LangToggle />
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: color-mix(in srgb, var(--bg) 85%, transparent);
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 50;
		backdrop-filter: saturate(180%) blur(10px);
		-webkit-backdrop-filter: saturate(180%) blur(10px);
	}
	h2 {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: -0.01em;
	}
	h2 a {
		color: var(--text);
	}
	h2 a:hover {
		color: var(--accent);
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		max-width: 1080px;
		margin: 0 auto;
	}
	nav a {
		color: var(--text);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
	}
	.internal-links {
		display: flex;
		gap: 0.15em;
	}
	.internal-links a {
		padding: 1em 0.7em;
		border-bottom: 2px solid transparent;
		color: var(--text-muted);
		transition:
			color 0.15s,
			border-color 0.15s;
	}
	.internal-links a:hover {
		color: var(--text);
	}
	.internal-links a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}
	.utility-links {
		display: flex;
		align-items: center;
		gap: 0.2em;
	}
	.github-link {
		padding: 0.5em;
		color: var(--text-muted);
		border-radius: 6px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}
	.github-link:hover {
		color: var(--text);
		background: var(--bg-elevated);
	}
	@media (max-width: 720px) {
		header {
			padding: 0 0.75em;
		}
		.github-link {
			display: none;
		}
		.internal-links a {
			padding: 0.875em 0.45em;
			font-size: 0.85rem;
		}
		h2 {
			font-size: 0.85rem;
		}
	}
</style>
