---
import { GITHUB_URL, SITE_AUTHOR } from '../consts';
import VisitCounter from './VisitCounter.astro';
import VisitorMap from './VisitorMap.astro';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<VisitorMap />
		<VisitCounter />
		<div class="copyright">
			&copy; {today.getFullYear()} {SITE_AUTHOR}
			<span class="dot">·</span>
			<a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
			<span class="dot">·</span>
			<span data-i18n-zh>用 Astro 构建</span><span data-i18n-en>Built with Astro</span>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1em 4em;
		border-top: 1px solid var(--border);
		color: var(--text-muted);
		text-align: center;
		font-size: 0.9em;
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 720px;
		margin: 0 auto;
	}
	.copyright {
		margin-top: 1.5em;
	}
	.copyright a {
		color: var(--text-muted);
	}
	.copyright a:hover {
		color: var(--accent);
	}
	.dot {
		margin: 0 0.4em;
		opacity: 0.5;
	}
</style>
