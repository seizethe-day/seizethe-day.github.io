---
// busuanzi 不蒜子 visit counter — free, no signup required.
// Numbers fill in via the async script after page load.
---
<p class="visit-counter">
	<span data-i18n-zh>本站累计访问</span><span data-i18n-en>Total views</span>
	<span id="busuanzi_value_site_pv">·</span>
	<span data-i18n-zh>次 · 访客</span><span data-i18n-en>· Unique visitors</span>
	<span id="busuanzi_value_site_uv">·</span>
	<span data-i18n-zh>人</span>
</p>
<script is:inline async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
<style>
	.visit-counter {
		font-size: 0.8em;
		color: rgb(var(--gray));
		margin-top: 1.2em;
		margin-bottom: 0;
	}
	.visit-counter span[id^='busuanzi_'] {
		font-weight: 600;
		margin: 0 0.15em;
	}
</style>
