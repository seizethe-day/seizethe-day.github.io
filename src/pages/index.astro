---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div data-i18n-zh>
				<h1>👋 你好</h1>
				<p>
					这里是 <strong>Carpe Diem</strong>——一个用来记录读书、写代码、生活随想的小角落。
				</p>
				<p>
					欢迎逛逛 <a href="/blog">所有文章</a>，或者了解一下 <a href="/about">关于我</a>。
				</p>
				<p style="font-size: 0.9em; color: rgb(var(--gray));">
					右上角可以切换中英文界面。
				</p>
			</div>
			<div data-i18n-en>
				<h1>👋 Hello</h1>
				<p>
					Welcome to <strong>Carpe Diem</strong> — a little corner for notes on reading, code,
					and life.
				</p>
				<p>
					Browse <a href="/blog">all posts</a>, or check out <a href="/about">about me</a>.
				</p>
				<p style="font-size: 0.9em; color: rgb(var(--gray));">
					Use the toggle in the top-right to switch UI language.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
