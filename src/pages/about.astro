---
import Layout from '../layouts/BlogPost.astro';
---

<Layout
	title="About"
	description="About this blog and its author."
	pubDate={new Date('May 27 2026')}
>
	<p>
		Hi, I'm <strong>Ariel</strong>.
	</p>
	<p>
		This blog is called <em>SeizeTheDay</em>. I use it to record books I've read, code I've
		written, places I've been, and thoughts I've had.
	</p>
	<p>
		Reach me by <a href="mailto:alice6161616@gmail.com">email</a> or on <a
			href="https://github.com/seizethe-day"
			target="_blank"
			rel="noopener">GitHub</a
		>.
	</p>
	<p style="color: var(--text-muted); font-size: 0.9em;">
		<em>This About page is a placeholder — edit <code>src/pages/about.astro</code> to make it yours.</em>
	</p>
</Layout>
